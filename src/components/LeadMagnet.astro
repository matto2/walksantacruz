---
import { Image } from "astro:assets";
import mapBg from "../assets/map-bg.jpg";
import wharfPhoto from "../assets/wharf.jpg";
---

<section class="full-bleed relative py-16 md:py-20">
  <div
    class="absolute inset-0 opacity-50"
    style={`background-image: url(${mapBg.src}); background-size: cover; background-position: center;`}
  ></div>
  <div class="container relative">
    <div style="max-width: 900px; margin: 0 auto;">
      <div class="flex flex-col md:flex-row md:items-center gap-8">
        <div style="flex: 0 0 auto; width: 100%;" class="md:max-w-xs">
          <Image
            src={wharfPhoto}
            alt="Santa Cruz Wharf"
            width={400}
            height={300}
            class="w-full rounded-xl object-cover"
            style="height: 220px;"
            loading="lazy"
          />
        </div>
        <div style="min-width: 0; flex: 1;">
          <h2 class="text-2xl md:text-3xl font-bold leading-tight mb-2">3 Perfect Days in Santa Cruz</h2>
          <p class="text-base md:text-lg leading-snug mb-5" style="color: #444; font-weight: 600;">A free local's guide for visitors and teams — yours instantly when you sign up.</p>
          <form action="https://app.kit.com/forms/9380967/subscriptions" method="post" style="width: 100%;">
            <div style="display: flex; flex-direction: row; gap: 8px; align-items: flex-start;" class="guide-form-fields">
              <input
                name="email_address"
                type="email"
                placeholder="Email Address"
                required
                aria-label="Email Address"
                style="flex: 1; min-width: 0; padding: 12px; border: 1px solid #dde0e4; border-radius: 4px; font-size: 15px; color: #555; background: #fff;"
              />
              <button type="submit" style="padding: 12px 20px; background-color: #ed672d; color: #fff; border: none; border-radius: 4px; font-size: 15px; font-weight: 700; cursor: pointer; white-space: nowrap; flex-shrink: 0;">Get the guide</button>
            </div>
            <p style="color: #666; font-size: 14px; margin-top: 8px;">We respect your privacy · Unsubscribe anytime</p>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
