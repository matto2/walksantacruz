---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import mapBg from "../assets/map-bg.jpg";

// Import private tour photos - EASILY SWAP THESE by changing the filenames below
import photo1 from "../assets/private-tours/IMG_0036.jpeg";
import photo2 from "../assets/private-tours/IMG_0371.jpeg";
import photo3 from "../assets/private-tours/IMG_0396.jpeg";
import photo4 from "../assets/private-tours/IMG_0468.jpeg";
import photo5 from "../assets/private-tours/IMG_1204.jpeg";
import photo6 from "../assets/private-tours/IMG_1766.jpeg";
import photo7 from "../assets/private-tours/IMG_1775.jpeg";
import photo8 from "../assets/private-tours/IMG_2591.jpg";
import heroPhoto from "../assets/private-tours/pantherBeach.jpg";
import streetTourPhoto from "../assets/IMG_8227.jpeg";
import outdoorTourPhoto from "../assets/IMG_8255.jpeg";
---

<Layout
  title="Custom Tours - Design Your Own Santa Cruz Experience | Walk Santa Cruz"
  description="Design a custom walking tour in Santa Cruz. Tell us your vision — surf history, architecture, food, filming locations, or anything in between. We'll build it around your group."
>
  <!-- Hero Section -->
  <section class="full-bleed relative py-8 md:py-12">
    <div
      class="absolute inset-0 opacity-50"
      style={`background-image: url(${mapBg.src}); background-size: cover; background-position: center;`}
    >
    </div>
    <div class="container relative">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Private Tours</h1>
        <p class="text-2xl text-muted-foreground font-medium mb-2">Design your own Santa Cruz experience.</p>
      </div>
    </div>
  </section>

  <!-- Intro Content -->
  <section class="container pt-6 pb-12 md:pt-6 md:pb-16">
    <div class="max-w-3xl mx-auto">

      <!-- Intro Text -->
      <p class="text-lg text-muted-foreground leading-relaxed mb-6">
        Private tours give you the full attention of a local expert with no strangers, no fixed schedule, and no topics you don't care about. You choose what to explore — surf history, architecture, hidden nature spots, filming locations, the university campus — and we build the walk around your group.
      </p>
      <p class="text-lg text-muted-foreground leading-relaxed mb-8">
        Perfect for families, couples, visiting groups, and anyone who wants a deeper experience than a public tour can offer.
      </p>

      <!-- Pricing -->
      <div class="bg-primary/5 border border-primary/20 rounded-xl px-6 py-5 mb-8">
        <p class="font-bold text-foreground mb-1">Pricing</p>
        <p class="text-muted-foreground">
          Custom pricing based on your group, interests, and vision. Solo travelers, couples, and small groups welcome — we'll provide a quote based on your needs.
          <a href="mailto:hello@walksantacruz.com?subject=Custom%20Tour%20Inquiry" class="text-primary underline ml-1">Email us to get started.</a>
        </p>
      </div>

      <!-- Hero photo -->
      <div class="mb-12">
        <div class="aspect-[3/2] rounded-lg overflow-hidden">
          <Image
            src={heroPhoto}
            alt="Panther Beach, Santa Cruz"
            class="w-full h-full object-cover"
            loading="lazy"
            quality={80}
          />
        </div>
      </div>

      <!-- Themed sections -->
      <h2 class="text-2xl md:text-3xl font-bold mb-8">What We Can Build for You</h2>

      <div class="space-y-8">
        <div>
          <h3 class="text-lg font-bold text-primary mb-2">For History & Architecture Lovers</h3>
          <p class="text-muted-foreground">Downtown Santa Cruz, Mission Hill, Beach Hill estates, Victorian neighborhoods, earthquake history, early California mission sites.</p>
        </div>
        <div>
          <h3 class="text-lg font-bold text-primary mb-2">For Surf & Coastal Enthusiasts</h3>
          <p class="text-muted-foreground">The full surf history walk, wetsuit innovation story, Steamer Lane, West Cliff Drive, Lighthouse Point, marine wildlife.</p>
        </div>
        <div>
          <h3 class="text-lg font-bold text-primary mb-2">For Nature & Outdoor Explorers</h3>
          <p class="text-muted-foreground">Wilder Ranch historic dairy, Cotoni-Coast Dairies conservation lands, Shark Fin Cove, Henry Cowell Ranch & Limekilns, coastal trail walks.</p>
        </div>
        <div>
          <h3 class="text-lg font-bold text-primary mb-2">Fully Custom</h3>
          <p class="text-muted-foreground">UCSC campus tours, movie filming locations, neighborhood deep-dives, family reunion walks, anniversary or special occasion experiences. If you have an idea, we'll build it.</p>
        </div>
      </div>

      <!-- Testimonial placeholder -->
      <!-- ADD PRIVATE TOUR TESTIMONIAL HERE -->

    </div>
  </section>

  <!-- Image Gallery Section -->
  <section class="container pb-12 md:pb-16">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold mb-8 text-center">
        Experience the Beauty of Santa Cruz
      </h2>

      <!-- EASY IMAGE SWAPS: Change the import filenames at the top of this file -->
      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="aspect-[4/3] rounded-lg overflow-hidden">
          <Image
            src={streetTourPhoto}
            alt="Tour group exploring a Santa Cruz neighborhood"
            class="w-full h-full object-cover"
            loading="lazy"
            quality={80}
          />
        </div>
        <div class="aspect-[4/3] rounded-lg overflow-hidden">
          <Image
            src={outdoorTourPhoto}
            alt="Guests on a private Santa Cruz walking tour"
            class="w-full h-full object-cover"
            loading="lazy"
            quality={80}
          />
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="aspect-[4/3] rounded-lg overflow-hidden">
          <Image
            src={photo1}
            alt="Private tour location in Santa Cruz"
            class="w-full h-full object-cover"
            loading="lazy"
            quality={80}
          />
        </div>
        <div class="aspect-[4/3] rounded-lg overflow-hidden">
          <Image
            src={photo2}
            alt="Beautiful Santa Cruz scenery"
            class="w-full h-full object-cover"
            loading="lazy"
            quality={80}
          />
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-6 mb-6">
        <div class="aspect-square rounded-lg overflow-hidden">
          <Image
            src={photo3}
            alt="Santa Cruz tour experience"
            class="w-full h-full object-cover"
            loading="lazy"
            quality={80}
          />
        </div>
        <div class="aspect-square rounded-lg overflow-hidden">
          <Image
            src={photo4}
            alt="Scenic Santa Cruz view"
            class="w-full h-full object-cover"
            loading="lazy"
            quality={80}
          />
        </div>
        <div class="aspect-square rounded-lg overflow-hidden">
          <Image
            src={photo5}
            alt="Santa Cruz coastline"
            class="w-full h-full object-cover"
            loading="lazy"
            quality={80}
          />
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="aspect-square rounded-lg overflow-hidden">
          <Image
            src={photo6}
            alt="Historic Santa Cruz location"
            class="w-full h-full object-cover"
            loading="lazy"
            quality={80}
          />
        </div>
        <div class="aspect-square rounded-lg overflow-hidden">
          <Image
            src={photo7}
            alt="Santa Cruz natural beauty"
            class="w-full h-full object-cover"
            loading="lazy"
            quality={80}
          />
        </div>
        <div class="aspect-square rounded-lg overflow-hidden">
          <Image
            src={photo8}
            alt="Santa Cruz exploration"
            class="w-full h-full object-cover"
            loading="lazy"
            quality={80}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Contact/Booking Section -->
  <section class="container py-12 md:py-16">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-3xl md:text-4xl font-bold mb-4" id="contact">
          Tell Us Your Vision
        </h2>
        <p class="text-xl text-muted-foreground">
          Email us with your group size, preferred date, and what you'd like to explore.
        </p>
      </div>

      <!-- Primary: email CTA -->
      <div class="bg-primary/5 border border-primary/20 rounded-xl p-8 text-center mb-10">
        <a
          href="mailto:hello@walksantacruz.com?subject=Custom%20Tour%20Inquiry"
          class="btn btn-lg mb-4"
        >
          Reserve Your Tour
        </a>
        <p class="text-sm text-muted-foreground">
          Or call <a href="tel:8312752566" class="font-semibold text-foreground">(831) 275-2566</a>
        </p>
      </div>

      <!-- Optional inquiry form -->
      <p class="text-center text-primary font-semibold mb-6">Or fill out a quick form and we'll reach out to you</p>

      <form
        name="custom-tour"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="form space-y-5"
      >
        <input type="hidden" name="form-name" value="custom-tour" />
        <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

        <div>
          <label for="name" class="block font-semibold mb-2">Name *</label>
          <input type="text" id="name" name="name" required class="w-full" />
        </div>
        <div>
          <label for="email" class="block font-semibold mb-2">Email *</label>
          <input type="email" id="email" name="email" required class="w-full" />
        </div>
        <div>
          <label for="groupsize" class="block font-semibold mb-2">Group size</label>
          <input type="text" id="groupsize" name="group-size" placeholder="e.g. 2 adults, 1 child" class="w-full" />
        </div>
        <div>
          <label for="date" class="block font-semibold mb-2">Preferred date</label>
          <input type="text" id="date" name="preferred-date" placeholder="e.g. July 15 or any Tuesday in August" class="w-full" />
        </div>
        <div>
          <label for="interests" class="block font-semibold mb-2">What would you like to explore? *</label>
          <textarea
            id="interests"
            name="interests"
            rows="4"
            required
            placeholder="Surf history, Victorian architecture, filming locations, food tour, UCSC campus, nature walk..."
            class="w-full"
          ></textarea>
        </div>
        <button type="submit" class="btn btn-lg w-full">Send Inquiry</button>
      </form>

    </div>
  </section>
</Layout>
