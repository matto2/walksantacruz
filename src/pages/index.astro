---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import TourCard from "../components/TourCard.astro";
import ReviewsCarousel from "../components/ReviewsCarousel.astro";
import { tours } from "../data/tours";
import heroImage from "../assets/downtown_hero.jpg";
import surfersHeroImage from "../assets/Surfers-Outside-Cowells_v5.jpg";
import mapBg from "../assets/map-bg.jpg";
import logoMyToque from "../assets/partner-logos/my-toque.png";
import logoMoonKissed from "../assets/partner-logos/MoonKissed.png";
import logoMythic from "../assets/partner-logos/mythic_logo.png";
import logoSuperSilver from "../assets/partner-logos/super-silver.webp";
import logoHiddenPeak from "../assets/partner-logos/hidden-peak.avif";
import logoArtisans from "../assets/partner-logos/artisans.avif";
import logoNicely from "../assets/partner-logos/nicely.webp";
import logoMissionHill from "../assets/partner-logos/mission-hill.webp";
import airbnbLogo from "../assets/Airbnb_Logo_Over_Gradient.jpg";
import tripadvisorLogo from "../assets/tripadvisor.svg";
import viatorLogo from "../assets/viator.webp";

// Set to false to revert to video hero
const USE_STATIC_HERO = true;

const allReviews = await getCollection("reviews");
const reviews = allReviews.sort((a, b) => a.data.order - b.data.order);
const surfTour = tours.find(t => t.slug === "surfing-beach-culture")!;
const downtownTour = tours.find(t => t.slug === "downtown-mission-hill")!;
const loopTour = tours.find(t => t.slug === "beach-hill-loop")!;
---

<Layout
  title="Walk Santa Cruz - Guided Walking Tours in Santa Cruz, CA"
  description="Discover the hidden gems and fascinating history of Santa Cruz with our expert-guided walking tours. Local guides, local stories."
>
  <!-- Hero Section - Full Bleed -->
  <section
    class="full-bleed relative min-h-[600px] md:min-h-[780px] flex items-start justify-center -mt-2 md:mt-0"
  >
    <!-- Hero background: static image or video (toggle USE_STATIC_HERO in frontmatter) -->
    <div class="absolute inset-0">
      {USE_STATIC_HERO ? (
        <Image
          src={surfersHeroImage}
          alt="Surfers outside Cowell's Beach, Santa Cruz"
          class="w-full h-full object-cover hero-static-img"
          loading="eager"
          quality={85}
        />
      ) : (
        <video
          id="hero-video"
          autoplay
          muted
          playsinline
          class="w-full h-full object-cover"
          poster={heroImage.src}
          aria-label="Santa Cruz walking tour background video"
        >
          <source src="/IMG_9072_web.mp4" type="video/mp4" />
          <Image
            src={heroImage}
            alt="Downtown Santa Cruz"
            class="w-full h-full object-cover"
            loading="eager"
            quality={80}
          />
        </video>
      )}
    </div>
    <!-- Dark gradient overlay: top fade for text legibility, bottom fade to blend into page -->
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(30,15,0,0.4) 0%, rgba(30,15,0,0.25) 50%, rgba(30,15,0,0.08) 72%, rgba(30,15,0,0) 82%, rgba(248,245,238,0.85) 100%);">
    </div>

    <div class="container relative z-10 text-center pt-8 pb-4 md:pt-36 md:pb-8">
      <h1
        class="text-[2.6rem] md:text-6xl lg:text-7xl font-bold leading-none mb-3 md:mb-6 text-white drop-shadow-md"
      >
        Where Surfing Came to America
      </h1>
      <p
        class="text-sm md:text-xl text-white font-semibold max-w-2xl mx-auto mb-6 md:mb-8 drop-shadow-md"
      >
        In 1885, Hawaiian princes rode waves here and changed the world. Walk the story with a local guide who knows it inside out.
      </p>
      <div class="flex flex-col items-center gap-3">
        <a href="/tours/surfing-beach-culture#book" data-astro-reload class="btn btn-lg w-full sm:w-auto">Book the Surf Walk</a>
        <a href="#tours" class="text-white underline underline-offset-2 text-sm font-semibold drop-shadow">View All Tours</a>
      </div>
      <a href="#reviews" class="mt-4 text-base font-bold text-white text-center drop-shadow whitespace-nowrap block"><span class="text-yellow-500">★★★★★</span> 5.0 rating</a>
    </div>
  </section>

  <!-- Start Here / Tours Section -->
  <section id="tours" class="container pt-2 pb-16 md:pt-4 md:pb-24">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold mb-8 text-center">
        Our Tours
      </h2>

      <!-- Surf Walk — full-width featured card -->
      <a href="/tours/surfing-beach-culture#book" data-astro-reload class="card p-0 flex flex-col md:flex-row overflow-hidden group mb-4">
        <div class="overflow-hidden md:w-2/5 flex-shrink-0">
          <Image src={surfTour.cardImage} alt={surfTour.cardImageAlt} class="w-full h-56 md:h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" quality={75} />
        </div>
        <div class="px-6 pt-4 pb-6 flex flex-col flex-1 md:justify-center">
          <div class="mb-3">
            <span class="text-xs font-bold uppercase tracking-widest text-primary">Surf & Coastal Experience</span>
          </div>
          <h3 class="text-2xl font-bold mb-3">Surfing & Beach Culture Walk</h3>
          <p class="text-muted-foreground mb-4 flex-1">The only tour in America that walks you through the exact spot where mainland surfing began in 1885. Created by a former surf magazine co-founder with 45 years in the water — and designed to be unforgettable.</p>
          <ul class="text-sm text-muted-foreground space-y-1 mb-6 [&_strong]:text-foreground">
            <li><strong>Best for:</strong> surfers, ocean lovers, first-time visitors, and anyone who wants a story they'll actually remember</li>
            <li><strong>Duration:</strong> 90 minutes</li>
            <li><strong>Schedule:</strong> Thu–Sun, 10am</li>
            <li><strong>Price:</strong> $45 adult · $30 child · Kids 5 &amp; under free</li>
          </ul>
          <span class="btn self-start">Book the Surf Walk →</span>
        </div>
      </a>

      <!-- Secondary tours -->
      <p class="text-sm font-bold uppercase tracking-widest text-muted-foreground text-center mt-10 mb-6">More Ways to Explore Santa Cruz</p>
      <div class="grid md:grid-cols-2 gap-8">

        <!-- Card 2: History & Neighborhood -->
        <a href="/tours/downtown-mission-hill" data-astro-reload class="card p-0 flex flex-col overflow-hidden group">
          <div class="overflow-hidden">
            <Image src={downtownTour.cardImage} alt={downtownTour.cardImageAlt} class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" quality={75} />
          </div>
          <div class="px-6 pt-3 pb-6 flex flex-col flex-1">
            <span class="text-xs font-bold uppercase tracking-widest text-primary mb-3">History & Neighborhood Experience</span>
            <h3 class="text-xl font-bold mb-3">Heart of Downtown Santa Cruz</h3>
            <p class="text-muted-foreground mb-4 flex-1">The original Walk Santa Cruz tour. A story-rich journey through downtown streets, local architecture, and the history and character of the city locals love.</p>
            <ul class="text-sm text-muted-foreground space-y-1 mb-6 [&_strong]:text-foreground">
              <li><strong>Best for:</strong> first-time visitors and shorter outings</li>
              <li><strong>Duration:</strong> 90 minutes</li>
              <li><strong>Schedule:</strong> Sat–Sun, 1pm</li>
              <li><strong>Price:</strong> $45 adult · $30 child · Kids 5 &amp; under free</li>
            </ul>
            <span class="btn w-full text-center">Explore the Downtown Tour →</span>
          </div>
        </a>

        <!-- Card 3: Deeper Local -->
        <a href="/tours/beach-hill-loop" data-astro-reload class="card p-0 flex flex-col overflow-hidden group">
          <div class="overflow-hidden">
            <Image src={loopTour.cardImage} alt={loopTour.cardImageAlt} class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" quality={75} />
          </div>
          <div class="px-6 pt-3 pb-6 flex flex-col flex-1">
            <span class="text-xs font-bold uppercase tracking-widest text-primary mb-3">Deeper Local Experience</span>
            <h3 class="text-xl font-bold mb-3">Beach Hill to Mission Hill Loop</h3>
            <p class="text-muted-foreground mb-4 flex-1">A broader, more immersive walk through multiple neighborhoods that ties together history, architecture, landscape, and the evolution of Santa Cruz over time.</p>
            <ul class="text-sm text-muted-foreground space-y-1 mb-6 [&_strong]:text-foreground">
              <li><strong>Best for:</strong> deeper exploration and history lovers</li>
              <li><strong>Duration:</strong> 2.5 hours</li>
              <li><strong>Schedule:</strong> Thu–Fri, 1pm</li>
              <li><strong>Price:</strong> $45 adult · $30 child · Kids 5 &amp; under free</li>
            </ul>
            <span class="btn w-full text-center">Explore the Loop Tour →</span>
          </div>
        </a>
      </div>
    </div>
  </section>


  <!-- Testimonials Section - HIDDEN FOR NOW -->
