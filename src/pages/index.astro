  <!-- Reviews Section -->
  <section id="reviews" class="full-bleed relative py-16 md:py-24">
    <div class="container relative">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-10">
        Guests Love It
      </h2>

      <!-- Featured quote: Sophia Adair -->
      <figure class="max-w-3xl mx-auto mb-14 text-center">
        <div class="flex justify-center gap-1 mb-4">
          {Array.from({ length: 5 }).map(() => (
            <svg class="w-5 h-5 text-yellow-500 fill-current" viewBox="0 0 24 24">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
