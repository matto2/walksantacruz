    >
    </div>
    <div class="container relative">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">
        What Our Guests Say
      </h2>

      <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
