              <div class="bg-card rounded-xl border p-4 flex items-center gap-4">
                <Image src={logoHiddenPeak} alt="Hidden Peak Teahouse" class="w-28 h-28 object-contain flex-shrink-0 rounded" loading="lazy" quality={80} />
