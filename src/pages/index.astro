  <!-- Local Perks Section -->
  <section class="full-bleed relative py-16 md:py-24">
    <div class="absolute inset-0 opacity-40" style={`background-image: url(${mapBg.src}); background-size: cover; background-position: center;`}></div>
    <div class="container relative">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-center">Your Tour Includes Exclusive Local Perks</h2>
        <p class="text-lg text-muted-foreground text-center max-w-2xl mx-auto mb-2">
          Enjoy discounts and special offers from favorite Santa Cruz shops, cafes, and downtown businesses. Each partner sets their own offer and redemption window.
        </p>
        <p class="text-xl font-bold text-center mb-12">Show your tour confirmation within the timeframe listed to redeem.</p>

        <div class="space-y-10">

          <!-- Same-Day -->
          <div>
            <h3 class="text-xs font-bold uppercase tracking-widest text-primary mb-4">Same-Day Perks</h3>
            <div class="grid sm:grid-cols-2 gap-4">
              <div class="bg-card rounded-xl border p-4 flex items-center gap-4">
                <Image src={logoMyToque} alt="MyTOQUE" class="w-28 h-28 object-contain flex-shrink-0 rounded" loading="lazy" quality={80} />
