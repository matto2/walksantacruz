  <!-- Local Perks Section -->
  <section class="full-bleed py-16 md:py-24">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-center">
          Your Tour Includes Exclusive Local Perks
        </h2>
        <p class="text-lg text-muted-foreground text-center max-w-2xl mx-auto mb-2">
          Enjoy discounts and special offers from favorite Santa Cruz shops,
          cafes, and downtown businesses. Each partner sets their own offer and
          redemption window.
        </p>
        <p class="text-xl font-bold text-center mb-12">
          Show your tour confirmation email to redeem.
        </p>

        <div class="space-y-10">
          <!-- Same-Day -->
          <div>
            <h3 class="text-xs font-bold uppercase tracking-widest text-primary mb-4">Same-Day Perks</h3>
            <div class="grid sm:grid-cols-2 gap-4">
              <div class="bg-card rounded-xl border p-4 flex items-center gap-4">
                <Image src={logoMyToque} alt="MyTOQUE" class="w-28 h-28 object-contain flex-shrink-0 rounded" loading="lazy" quality={80} />
                <div>
                  <p class="text-sm text-muted-foreground">MyTOQUE</p>
                  <p class="text-lg font-bold leading-tight">Free 100 ml olive oil with $25 purchase</p>
                </div>
              </div>
              <div class="bg-card rounded-xl border p-4 flex items-center gap-4">
                <Image src={logoMoonKissed} alt="Moon Kissed" class="w-28 h-28 object-contain flex-shrink-0 rounded" loading="lazy" quality={80} />
                <div>
                  <p class="text-sm text-muted-foreground">Moon Kissed</p>
                  <p class="text-lg font-bold leading-tight">10% off</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Within 3 Days -->
          <div>
            <h3 class="text-xs font-bold uppercase tracking-widest text-primary mb-4">Within 3 Days</h3>
            <div class="grid sm:grid-cols-2 gap-4">
              <div class="bg-card rounded-xl border p-4 flex items-center gap-4">
                <Image src={logoMythic} alt="Mythic Games" class="w-28 h-28 object-contain flex-shrink-0 rounded" loading="lazy" quality={80} />
