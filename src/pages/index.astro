              <div class="bg-card rounded-xl border p-4 flex items-center gap-4">
                <Image src={logoArtisans} alt="Artisans & Agency" class="w-28 h-28 object-contain flex-shrink-0 rounded" loading="lazy" quality={80} />
                <div>
                  <p class="text-sm text-muted-foreground">Artisans & Agency</p>
                  <p class="text-lg font-bold leading-tight">10% off</p>
                </div>
              </div>
              <div class="bg-card rounded-xl border p-4 flex items-center gap-4">
                <Image src={logoNicely} alt="Nicely" class="w-28 h-28 object-contain flex-shrink-0 rounded" loading="lazy" quality={80} />
                <div>
                  <p class="text-sm text-muted-foreground">Nicely</p>
                  <p class="text-lg font-bold leading-tight">10% off, including existing sales</p>
                </div>
              </div>
              <div class="bg-card rounded-xl border p-4 flex items-center gap-4">
                <Image src={logoMissionHill} alt="Mission Hill Coffee & Creamery" class="w-28 h-28 object-contain flex-shrink-0 rounded" loading="lazy" quality={80} />
