---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import TourCard from "../components/TourCard.astro";
import ReviewsCarousel from "../components/ReviewsCarousel.astro";
import LeadMagnet from "../components/LeadMagnet.astro";
import LeadMagnetKit from "../components/LeadMagnetKit.astro";
import { tours } from "../data/tours";
import heroImage from "../assets/downtown_hero.jpg";
import newHeroImage from "../assets/Hero_IMG_0299.jpg";
import mapBg from "../assets/map-bg.jpg";
import LookoutLogo from "../assets/LookoutLogo.png";
import mattBioPic from "../assets/matt-bio-pic_with-HAT.jpg";
import logoMyToque from "../assets/partner-logos/my-toque.png";
import logoMoonKissed from "../assets/partner-logos/MoonKissed.png";
import logoMythic from "../assets/partner-logos/mythic_logo.png";
import logoSuperSilver from "../assets/partner-logos/super-silver.webp";
import logoHiddenPeak from "../assets/partner-logos/hidden-peak.avif";
import logoArtisans from "../assets/partner-logos/artisans.avif";
import logoNicely from "../assets/partner-logos/nicely.webp";
import logoMissionHill from "../assets/partner-logos/mission-hill.webp";
import airbnbLogo from "../assets/Airbnb_Logo_Over_Gradient.jpg";
import tripadvisorLogo from "../assets/tripadvisor.svg";
import viatorLogo from "../assets/viator.webp";
import tripadvisorBadge from "../assets/tripadvisor-5-star1.avif";
import googleBadge from "../assets/5-star-google-white-min.avif";

// Set to false to revert to video hero
const USE_STATIC_HERO = true;

const allReviews = await getCollection("reviews");
const reviews = allReviews.sort((a, b) => a.data.order - b.data.order);
const surfTour = tours.find((t) => t.slug === "surfing-beach-culture")!;
const downtownTour = tours.find((t) => t.slug === "downtown-mission-hill")!;
const loopTour = tours.find((t) => t.slug === "beach-hill-loop")!;
---

<Layout
  title="Walk Santa Cruz - Guided Walking Tours in Santa Cruz, CA"
  description="Discover the hidden gems and fascinating history of Santa Cruz with our expert-guided walking tours. Local guides, local stories."
>
  <!-- Hero Section - Full Bleed -->
  <section
    class="full-bleed relative min-h-[520px] md:min-h-[780px] flex items-center md:items-start justify-center -mt-2"
  >
    <!-- Hero background: static image or video (toggle USE_STATIC_HERO in frontmatter) -->
    <div class="absolute inset-0 overflow-hidden">
      {
        USE_STATIC_HERO ? (
          <Image
            src={newHeroImage}
            alt="A small group on a guided walking tour in Santa Cruz"
            class="absolute inset-0 w-full h-full object-cover object-center"
            loading="eager"
            quality={85}
          />
        ) : (
          <video
            id="hero-video"
            autoplay
            muted
            playsinline
            class="w-full h-full object-cover"
            poster={heroImage.src}
            aria-label="Santa Cruz walking tour background video"
          >
            <source src="/IMG_9072_web.mp4" type="video/mp4" />
            <Image
              src={heroImage}
              alt="Downtown Santa Cruz"
              class="w-full h-full object-cover"
              loading="eager"
              quality={80}
            />
          </video>
        )
      }
    </div>
    <!-- Scrim: transparent at top, dark at bottom -->
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0) 40%, rgba(0,0,0,0.25) 75%, rgba(0,0,0,0.40) 100%);"></div>

    <div class="container relative z-10 text-center py-4 md:pt-36 md:pb-8">
      <h1
        class="text-[calc((100vw_-_1.5rem)/9.6)] leading-[1.05] sm:text-[2.6rem] sm:leading-none md:text-6xl lg:text-7xl xl:text-[6rem] font-bold mb-3 md:mb-6 text-white drop-shadow-md px-3 md:px-0"
      >
        Santa Cruz Walking Tours
      </h1>
      <p
        class="text-[0.975rem] md:text-[1.4rem] xl:text-[2rem] leading-tight text-white font-semibold max-w-2xl mx-auto mb-6 md:mb-8 drop-shadow-md"
      >
        Hidden History, Culture, and Stories—Led by Local Guides
      </p>
      <div class="flex items-center justify-center">
        <a
          href="mailto:hello@walksantacruz.com?subject=Tour%20Booking"
          class="btn btn-lg xl:h-[60px] xl:px-9 xl:text-[1.3rem]"
        >
          Reserve Your Tour
        </a>
      </div>
      <a href="#reviews" class="mt-6 block" style="filter: drop-shadow(0 4px 12px rgba(0,0,0,0.5));">
        <div class="flex items-center justify-center gap-4 md:gap-6 mb-2 md:mb-3">
          <Image src={tripadvisorBadge} alt="TripAdvisor 5-star rating" class="h-[58px] md:h-[108px] w-auto drop-shadow" loading="eager" />
          <Image src={googleBadge} alt="Google 5-star rating" class="h-[58px] md:h-[108px] w-auto drop-shadow" loading="eager" />
        </div>
        <p class="text-sm md:text-xl text-white text-center drop-shadow font-medium">Trusted by travelers with 12+ five-star reviews</p>
      </a>
    </div>
  </section>

  <!-- Reviews Section -->
  <section id="reviews" class="full-bleed relative pt-16 pb-4 md:pt-20 md:pb-6">
    <div class="container relative">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-10">
        Guests Love Our Tours!
      </h2>

      <ReviewsCarousel
        reviews={reviews}
        airbnbLogo={airbnbLogo}
        tripadvisorLogo={tripadvisorLogo}
        viatorLogo={viatorLogo}
      />

      <p class="text-center text-sm text-muted-foreground mt-10">
        Reviewed on Google · Airbnb · TripAdvisor · Viator
      </p>
      <div class="text-center mt-8 mb-6">
        <a href="mailto:hello@walksantacruz.com?subject=Tour%20Booking" class="btn btn-lg">Book Now</a>
      </div>
      <p class="text-center text-sm text-muted-foreground mt-6 mb-1">⭐⭐⭐⭐⭐ 12+ five-star reviews</p>
      <p class="text-center text-sm text-muted-foreground">Questions? Call or text us at <a href="tel:8312752566" class="font-semibold text-foreground">831-275-2566</a></p>
    </div>
  </section>

  <!-- Featured In Bar -->
  <div class="full-bleed relative py-4 md:py-6">
    <div
      class="absolute inset-0 opacity-50"
      style={`background-image: url(${mapBg.src}); background-size: cover; background-position: center;`}
    >
    </div>
    <div class="flex items-center justify-center gap-4 relative">
      <span class="text-xl md:text-[1.75rem] font-bold" style="color: #ed672d;">Featured in</span>
      <a
        href="https://lookout.co/new-downtown-walking-tour-aspires-to-tell-santa-cruzs-hidden-stories/story"
        target="_blank"
        rel="noopener noreferrer"
      >
        <Image
          src={LookoutLogo}
          alt="Lookout Santa Cruz"
          width={1179}
          height={327}
          class="h-8 md:h-12 w-auto object-contain"
        />
      </a>
    </div>
  </div>

  <!-- Start Here / Tours Section -->
  <section id="tours" class="container pt-2 pb-16 md:pt-4 md:pb-24">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold mb-8 text-center">Choose Your Tour</h2>

      <!-- Tour cards -->
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Card 1: Surf Walk -->
        <a
          href="/tours/surfing-beach-culture"
          data-astro-reload
          class="card p-0 flex flex-col overflow-hidden group"
        >
          <div class="overflow-hidden relative">
            <Image
              src={surfTour.cardImage}
              alt={surfTour.cardImageAlt}
              class="w-full h-56 object-cover object-[center_30%] group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
              quality={75}
            />
          </div>
          <div class="px-6 pt-3 pb-6 flex flex-col flex-1">
            <span class="self-start text-xs font-bold uppercase tracking-widest rounded-full px-3 py-1 mb-3" style="background-color: #d0eef5; color: #007a99;">Surf & Coastal Experience</span>
            <h3 class="text-xl font-bold mb-3">Surfing & Beach Culture Walk</h3>
            <p class="text-muted-foreground mb-4 flex-1">
              Discover the exact spot where mainland surfing began in 1885. Led by
              a local with 45 years in the water — and designed
              to be unforgettable.
            </p>
            <ul class="text-sm text-muted-foreground space-y-1 mb-6 [&_strong]:text-foreground">
              <li><strong>Best for:</strong> surfers, ocean lovers, first-time visitors</li>
              <li><strong>Duration:</strong> 90 minutes</li>

              <li><strong>Pricing:</strong> $180 for up to 4 guests · +$45 for each additional guest · Kids 12 &amp; under free · Contact us for groups over 10</li>
            </ul>
            <span class="btn w-full text-center">Explore this tour →</span>
          </div>
        </a>

        <!-- Card 2: History & Neighborhood -->
        <a
          href="/tours/downtown-mission-hill"
          data-astro-reload
          class="card p-0 flex flex-col overflow-hidden group"
        >
          <div class="overflow-hidden">
            <Image
              src={downtownTour.cardImage}
              alt={downtownTour.cardImageAlt}
              class="w-full h-56 object-cover object-[center_20%] group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
              quality={75}
            />
          </div>
          <div class="px-6 pt-3 pb-6 flex flex-col flex-1">
            <span class="self-start text-xs font-bold uppercase tracking-widest rounded-full px-3 py-1 mb-3" style="background-color: #d0eef5; color: #007a99;">History & Neighborhood Experience</span>
            <h3 class="text-xl font-bold mb-3">Heart of Downtown Santa Cruz</h3>
            <p class="text-muted-foreground mb-4 flex-1">
              The original Walk Santa Cruz tour. A story-rich journey through
              downtown streets, local architecture, and the history and
              character of the city locals love.
            </p>
            <ul class="text-sm text-muted-foreground space-y-1 mb-6 [&_strong]:text-foreground">
              <li><strong>Best for:</strong> first-time visitors and shorter outings</li>
              <li><strong>Duration:</strong> 90 minutes</li>

              <li><strong>Pricing:</strong> $180 for up to 4 guests · +$45 for each additional guest · Kids 12 &amp; under free · Contact us for groups over 10</li>
            </ul>
            <span class="btn w-full text-center">Explore this tour →</span>
          </div>
        </a>

        <!-- Card 3: Deeper Local -->
        <a
          href="/tours/beach-hill-loop"
          data-astro-reload
          class="card p-0 flex flex-col overflow-hidden group"
        >
          <div class="overflow-hidden">
            <Image
              src={loopTour.cardImage}
              alt={loopTour.cardImageAlt}
              class="w-full h-56 object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
              quality={75}
            />
          </div>
          <div class="px-6 pt-3 pb-6 flex flex-col flex-1">
            <span class="self-start text-xs font-bold uppercase tracking-widest rounded-full px-3 py-1 mb-3" style="background-color: #d0eef5; color: #007a99;">Old waterfront &amp; downtown stories</span>
            <h3 class="text-xl font-bold mb-3">Beach Hill to Downtown Santa Cruz Loop</h3>
            <p class="text-muted-foreground mb-4 flex-1">
              Beach Hill's grand historic estates plus the Victorian, Craftsman, and Art Deco streets of downtown — neighborhoods worth experiencing in a whole new way.
            </p>
            <ul class="text-sm text-muted-foreground space-y-1 mb-6 [&_strong]:text-foreground">
              <li><strong>Best for:</strong> deeper exploration and history lovers</li>
              <li><strong>Duration:</strong> 90 minutes</li>

              <li><strong>Pricing:</strong> $180 for up to 4 guests · +$45 for each additional guest · Kids 12 &amp; under free · Contact us for groups over 10</li>
            </ul>
            <span class="btn w-full text-center">Explore this tour →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials Section - HIDDEN FOR NOW -->
