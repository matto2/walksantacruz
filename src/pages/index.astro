  <!-- Sophia Block -->
  <section class="container pt-8 pb-16 md:pt-10 md:pb-20">
    <figure class="max-w-3xl mx-auto text-center">
      <div class="flex justify-center gap-1 mb-4">
        {
          Array.from({ length: 5 }).map(() => (
            <svg class="w-5 h-5 text-yellow-500 fill-current" viewBox="0 0 24 24">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
            </svg>
          ))
        }
      </div>
      <blockquote class="text-xl md:text-2xl font-semibold leading-snug text-foreground mb-4">
        "Tours are relaxed, entertaining, enlightening, and highly recommended
        for anyone seeking a bigger, more flavorful slice of Santa Cruz
        history."
      </blockquote>
      <figcaption class="text-sm text-muted-foreground">
        — Sophia &nbsp;·&nbsp; March 2026 &nbsp;·&nbsp;
        <a href="https://share.google/xDtZXgKdz5xZL9Ruj" target="_blank" rel="noopener noreferrer" class="underline">Google Review</a>
      </figcaption>
    </figure>
  </section>

  <!-- Meet Your Guide Section -->
  <section class="full-bleed relative py-16 md:py-20">
    <div
      class="absolute inset-0 opacity-50"
      style={`background-image: url(${mapBg.src}); background-size: cover; background-position: center;`}
    >
    </div>
    <div class="container relative">
      <div class="max-w-5xl mx-auto flex flex-col md:flex-row gap-10 md:gap-16 items-center">
        <div class="flex-shrink-0">
          <Image
            src={mattBioPic}
            alt="Matt O'Leary, Walk Santa Cruz guide"
            width={320}
            height={400}
            class="rounded-xl object-cover w-56 md:w-72 h-64 md:h-80"
            loading="lazy"
          />
        </div>
        <div class="flex flex-col gap-5">
          <h2 class="text-3xl md:text-4xl font-bold">Meet Your Guide</h2>
          <p class="text-base md:text-lg leading-relaxed">
            Matt O'Leary leads history and culture walks across Santa Cruz—from the coastline and Beach Hill to downtown, the old Mission site, and surrounding Victorian neighborhoods. Each walk explores a different layer of the city, from its surf heritage to its early development and architectural character.
          </p>
          <p class="text-base md:text-lg leading-relaxed">
            A Santa Cruz surfer since the late 1970s, co-founder of <em>The Juice</em> surf magazine, and a competitor in the O'Neill Coldwater Classic, Matt pairs firsthand knowledge of the local surf scene with a deep interest in the people, places, and events that shaped the city both along the coast and in the downtown historic district.
          </p>
          <blockquote class="border-l-4 border-primary pl-4 italic text-muted-foreground">
            "Matt has extensive local history to share and also invites hearing stories from other locals and visitors." — Alison, Google Review
          </blockquote>
          <a href="/about" class="text-primary font-semibold">More About Matt →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="container pt-4 pb-16 md:pt-4 md:pb-24">
    <div class="max-w-2xl mx-auto text-center">
      <h3 class="text-2xl md:text-3xl font-bold mb-4">Ready to book your tour?</h3>
      <p class="text-muted-foreground mb-6">
        Email us with your preferred tour, date, and group size — we'll confirm availability and get you set up.
      </p>
      <a
        href="mailto:hello@walksantacruz.com?subject=Tour%20Booking"
        class="btn btn-lg"
      >
        Email to Reserve →
      </a>
      <p class="text-sm text-muted-foreground mt-4">
        Or call <a href="tel:8312752566" class="font-semibold text-foreground">(831) 275-2566</a>
      </p>
    </div>
  </section>

  <!-- GIFT CARDS HIDDEN — restore by removing these comment tags
  <section class="full-bleed py-16 md:py-20" style="background-color: #007a99;">
    <div class="container text-center text-white">
      <h2 class="text-4xl md:text-6xl font-bold mb-3">🎁 Gift Cards</h2>
      <p class="text-xl md:text-2xl mb-8 font-medium">The perfect Santa Cruz gift</p>
