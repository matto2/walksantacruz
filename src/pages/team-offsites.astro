---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import mapBg from "../assets/map-bg.jpg";
import mattPhoto from "../assets/me-talking-on-a-tour1.jpeg";
import mattWestCliff from "../assets/surf-tour/matt-surfing-1990.jpg";
import teamPhoto from "../assets/teambuilding/team1.jpg";
import barrelPhoto from "../assets/gooch-barrel-photo by Dave Nelson.png";
---

<Layout
  title="Team Offsites & Group Experiences in Santa Cruz | Walk Santa Cruz"
  description="Customized walking tours and group experiences for team offsites in Santa Cruz. Choose from three signature tours or design something entirely your own."
>
  <!-- Hero Section -->
  <section class="container pt-10 pb-8 md:pt-16 md:pb-12">
    <div class="max-w-3xl mx-auto mb-8">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
        Team Offsites &amp; Group Experiences
      </h1>
      <p class="text-lg md:text-xl text-muted-foreground leading-relaxed mb-6">
        Santa Cruz is one of the most story-rich places on the California coast. A guided walk here gives your team something most offsites don't — genuine curiosity, real conversation, and a place that stays with people.
      </p>
      <a href="#contact" class="btn btn-lg">Get in Touch</a>
    </div>

    <div class="max-w-4xl mx-auto mt-10">
      <div class="rounded-lg overflow-hidden">
        <Image
          src={teamPhoto}
          alt="Group on a walking tour in Santa Cruz"
          class="w-full h-auto object-cover object-right"
          loading="eager"
          quality={85}
        />
      </div>
    </div>
  </section>

  <!-- Body Copy -->
  <section class="container py-12 md:py-16">
    <div class="max-w-3xl mx-auto space-y-5 text-lg text-muted-foreground leading-relaxed">
      <p>
        No two groups are the same, so the experience doesn't have to be either. Whether you have four people or forty, whether you want a focused hour or a half-day adventure, we'll build something around your group's interests, your schedule, and where you're staying.
      </p>
      <p>
        Your team can choose from any of the three existing tours — each one a distinct window into Santa Cruz — or we can design something entirely custom: a route built around your neighborhood, your industry, or the themes that matter to your group. History, architecture, surf culture, coastal ecology, the stories behind the city's most unlikely moments — there's no shortage of material.
      </p>
      <p>
        Side-by-side walking is where real conversation happens. The format is relaxed by design, and the stories give people something to talk about — during lunch, on the drive home, months later.
      </p>
    </div>
  </section>

  <!-- Choose Your Adventure -->
  <section class="full-bleed relative py-12 md:py-16">
    <div class="absolute inset-0 opacity-50" style={`background-image: url(${mapBg.src}); background-size: cover; background-position: center;`}></div>
    <div class="container relative">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold mb-4">Start with a Tour — or Build Something New</h2>
        <p class="text-lg text-muted-foreground leading-relaxed mb-10">
          Each of the three signature tours works well for private groups and can be adapted to your needs. Or skip the menu entirely and we'll design something from scratch.
        </p>

        <div class="space-y-6">
          <div class="bg-background/90 rounded-xl p-6">
            <h3 class="font-bold text-lg mb-1">
              <a href="/tours/surfing-beach-culture" class="text-foreground">Santa Cruz Surf Walk &rarr;</a>
            </h3>
            <p class="text-muted-foreground">The origin story of West Coast surfing, told at the exact spots where it happened. From Hawaiian princes at the rivermouth in 1885 to Jack O'Neill's first Santa Cruz surf shop in an old real estate office, out along West Cliff Drive to Steamer Lane. About 90 minutes, coastal path the entire way.</p>
          </div>

          <div class="bg-background/90 rounded-xl p-6">
            <h3 class="font-bold text-lg mb-1">
              <a href="/tours/downtown-mission-hill" class="text-foreground">Heart of Downtown Santa Cruz &rarr;</a>
            </h3>
            <p class="text-muted-foreground">A relaxed 90-minute walk through the historic core — the Mission, the 1989 earthquake rebuild, Victorian architecture, the creative district that came after. Good for groups who want to understand the city itself.</p>
          </div>

          <div class="bg-background/90 rounded-xl p-6">
            <h3 class="font-bold text-lg mb-1">
              <a href="/tours/beach-hill-loop" class="text-foreground">Beach Hill to Downtown Loop &rarr;</a>
            </h3>
            <p class="text-muted-foreground">Starts at the beach and winds through Beach Hill's grand Victorian estates before descending into downtown via a hidden staircase locals love. A 90-minute loop that covers two of the city's most distinctive neighborhoods.</p>
          </div>

          <div class="bg-background/90 rounded-xl p-6 border-l-4 border-primary">
            <h3 class="font-bold text-lg mb-1">Completely Custom</h3>
            <p class="text-muted-foreground">Tell us where your group is staying, what they're interested in, and how much time you have. We'll design a route and a story arc around that — starting from your hotel or rental if you're in the downtown or beach area, or connecting multiple neighborhoods for a longer half-day experience.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Surf Photo with Caption -->
  <section class="container py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <div class="rounded-lg overflow-hidden mb-3">
        <Image
          src={barrelPhoto}
          alt="Surfer getting barrelled at Steamer Lane, Santa Cruz — photo by Dave Nelson"
          class="w-full h-auto"
          loading="lazy"
          quality={85}
        />
      </div>
      <p class="text-sm text-muted-foreground italic">
        The Surf Walk brings your team into the stoke — the history, the culture, the aloha spirit that runs through this coast. &nbsp;·&nbsp; Photo: Dave Nelson
      </p>
    </div>
  </section>

  <!-- Guide Section -->
  <section class="container py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold mb-8">A Guide Who's Passionate About Local History &amp; Culture</h2>
      <div class="flex flex-col md:flex-row gap-8 items-start">
        <div class="w-full md:w-1/3 flex-shrink-0">
          <div class="aspect-square rounded-lg overflow-hidden">
            <Image
              src={mattPhoto}
              alt="Matt O'Leary leading a walking tour in Santa Cruz"
              class="w-full h-full object-cover"
              loading="lazy"
              quality={80}
            />
          </div>
        </div>
        <div class="text-muted-foreground space-y-4">
          <p class="text-lg leading-relaxed">
            Matt O'Leary co-founded <em>The Juice</em> surfing magazine and competed in the O'Neill Coldwater Classic in the '90s. He's surfed Steamer Lane since the late 1970s. His research spans years of Santa Cruz history — from the Awaswas-speaking Ohlone people through the Victorian era to the surf culture that put this city on the global map.
          </p>
          <p class="text-lg leading-relaxed">
            Stories you won't find anywhere else, told by someone who lived them.
          </p>
        </div>
      </div>
      <div class="mt-8">
        <Image
          src={mattWestCliff}
          alt="Matt surfing a small cove off West Cliff, 1990"
          class="w-full rounded-lg"
          loading="lazy"
          quality={85}
        />
        <p class="text-sm text-muted-foreground mt-2 italic">West Cliff, 1990 — Photo: Bud Clark</p>
      </div>
    </div>
  </section>

  <!-- Case Study: Santa Cruz Hostel Society -->
  <section class="full-bleed relative py-12 md:py-16">
    <div class="absolute inset-0 opacity-50" style={`background-image: url(${mapBg.src}); background-size: cover; background-position: center;`}></div>
    <div class="container relative">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold mb-6">How We Did This for Santa Cruz Hostel Society</h2>
        <div class="text-lg text-muted-foreground leading-relaxed space-y-4 mb-8">
          <p>
            The team at <a href="https://santacruzhostel.org/" target="_blank" rel="noopener noreferrer" class="text-primary underline">Santa Cruz Hostel Society</a> hosts groups from around the world at their Beach Hill property. They wanted their visiting teams to actually experience what makes Santa Cruz special — not just see it from a window.
          </p>
          <p>
            We designed a custom walking tour right from their front door: Beach Hill's transformation from industrial waterfront to surf culture hub, the breaks that changed wetsuit technology, Victorian neighborhoods shaped by 150 years of coastal tourism.
          </p>
          <p>
            Two hours of genuine exploration along the coast, with stories that gave people something to talk about long after.
          </p>
        </div>

        <div class="bg-card rounded-xl border-l-4 border-primary p-8 mb-8 shadow-sm">
          <svg class="w-8 h-8 text-primary/30 mb-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
          </svg>
          <p class="text-lg md:text-xl font-semibold text-foreground leading-relaxed mb-6">
            "Meet your favorite new Santa Cruz must-try activity: a historic walking tour! With a breadth of knowledge tapping into historic true crime, architecture, and local legends, Walk Santa Cruz is putting the 'story' in 'history'. Next time you're in Santa Cruz, you'll want to book a tour. It's Santa Cruz Hostel approved!"
          </p>
          <div class="flex items-center gap-3">
            <div>
              <p class="font-bold text-foreground">Santa Cruz Hostel Society</p>
              <a href="https://santacruzhostel.org/" target="_blank" rel="noopener noreferrer" class="text-sm text-primary underline">santacruzhostel.org</a>
            </div>
          </div>
        </div>

        <div class="bg-secondary/30 border border-secondary rounded-lg p-6">
          <h3 class="font-bold text-lg mb-2">Need a Base for Your Multi-Day Offsite?</h3>
          <p class="text-muted-foreground">
            <a href="https://santacruzhostel.org/" target="_blank" rel="noopener noreferrer" class="text-primary underline">Santa Cruz Hostel Society</a> offers affordable group accommodations right on Beach Hill — walking distance to the beach, Boardwalk, downtown, and wharf. Perfect for teams that want to stay where the action is without the hotel premium.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section id="contact" class="container py-12 md:py-16">
    <div class="max-w-2xl mx-auto">

      <!-- Pull Quote -->
      <figure class="mb-12 text-center">
        <div class="flex justify-center gap-1 mb-4">
          {Array.from({ length: 5 }).map(() => (
            <svg class="w-5 h-5 text-yellow-500 fill-current" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
            </svg>
          ))}
        </div>
        <blockquote class="text-xl md:text-2xl font-semibold leading-snug text-foreground mb-3">
          "Tours are relaxed, entertaining, enlightening, and highly recommended for anyone seeking a bigger, more flavorful slice of Santa Cruz history."
        </blockquote>
        <figcaption class="text-sm text-muted-foreground">
          — Sophia &nbsp;·&nbsp; March 2026 &nbsp;·&nbsp;
          <a href="https://share.google/xDtZXgKdz5xZL9Ruj" target="_blank" rel="noopener noreferrer" class="underline">Google Review</a>
        </figcaption>
      </figure>

      <div class="text-center mb-8">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Plan Your Group Experience</h2>
        <p class="text-lg text-muted-foreground">
          Tell us about your group — size, dates, where you're staying, and what you're hoping for. We'll take it from there.
        </p>
      </div>

      <form
        name="team-offsite"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="form space-y-6 mb-8"
      >
        <input type="hidden" name="form-name" value="team-offsite" />
        <p class="hidden">
          <label>
            Don't fill this out if you're human: <input name="bot-field" />
          </label>
        </p>

        <div class="grid sm:grid-cols-2 gap-6">
          <div>
            <label for="name" class="block font-semibold mb-2">Your Name *</label>
            <input type="text" id="name" name="name" required class="w-full" />
          </div>
          <div>
            <label for="org-name" class="block font-semibold mb-2">Organization</label>
            <input type="text" id="org-name" name="org-name" class="w-full" />
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-6">
          <div>
            <label for="email" class="block font-semibold mb-2">Email *</label>
            <input type="email" id="email" name="email" required class="w-full" />
          </div>
          <div>
            <label for="phone" class="block font-semibold mb-2">Phone</label>
            <input type="tel" id="phone" name="phone" class="w-full" />
          </div>
        </div>

        <div>
          <label for="details" class="block font-semibold mb-2">Group size, preferred dates, and anything else we should know *</label>
          <textarea
            id="details"
            name="details"
            rows="4"
            required
            placeholder="e.g. 12 people, late May, staying near the Boardwalk, interested in surf history"
            class="w-full"></textarea>
        </div>

        <button type="submit" class="btn btn-lg w-full">Send Inquiry</button>
      </form>

      <div class="flex flex-wrap justify-center gap-4 mb-8">
        <a href="tel:8312752566" class="btn btn-secondary inline-flex items-center gap-2">
          831-275-2566
        </a>
        <a href="mailto:hello@walksantacruz.com" class="btn btn-secondary inline-flex items-center gap-2">
          hello@walksantacruz.com
        </a>
        <a href="https://wa.me/18312752566" target="_blank" rel="noopener noreferrer" class="btn btn-secondary inline-flex items-center gap-2">
          WhatsApp
        </a>
      </div>

      <p class="text-sm text-muted-foreground text-center">
        Worked with teams from startups to nonprofits to creative agencies. References available upon request.
      </p>
    </div>
  </section>
</Layout>
