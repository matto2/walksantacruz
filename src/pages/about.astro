---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import aboutPhoto from "../assets/me-talking-on-a-tour1.jpeg";
import heroPhoto from "../assets/Matt-by-moore-creek.jpg";
import pescaderoPhoto from "../assets/walking-pescadero.jpg";
import downtownTourPhoto from "../assets/IMG_8220.jpeg";
import churchTowerTourPhoto from "../assets/IMG_8224.jpeg";
import mapBg from "../assets/map-bg.jpg";
---

<Layout
  title="About Your Guide - Matt O'Leary | Walk Santa Cruz"
  description="Meet Matt O'Leary, your local Santa Cruz guide. A native with a passion for sharing the rich history and vibrant culture of our coastal community."
>
  <!-- Hero Section -->
  <section class="full-bleed relative py-8 md:py-12">
    <div
      class="absolute inset-0 opacity-50"
      style={`background-image: url(${mapBg.src}); background-size: cover; background-position: center;`}
    >
    </div>
    <div class="container relative">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">About Your Guide</h1>
        <p class="text-xl text-muted-foreground">
          Local expertise, passionate storytelling
        </p>
      </div>
    </div>
  </section>

  <!-- About Content -->
  <section class="container pt-6 pb-12 md:pt-6 md:pb-16">
    <div class="max-w-3xl mx-auto">
      <!-- Hero photo at top -->
      <div class="mb-12">
        <div class="aspect-square rounded-lg overflow-hidden">
          <Image
            src={heroPhoto}
            alt="Matt O'Leary by Moore Creek"
            class="w-full h-full object-cover"
            loading="eager"
            quality={80}
          />
        </div>
      </div>

      <!-- Surf Credentials -->
      <div class="bg-primary/5 border border-primary/20 rounded-xl px-6 py-5 mb-10">
        <p class="font-bold text-foreground mb-2">Matt O'Leary</p>
        <ul class="text-muted-foreground space-y-1 text-sm">
          <li>Co-founder, <em>The Juice</em> surf magazine (early '90s)</li>
          <li>Competitor, O'Neill Coldwater Classic</li>
          <li>Surfing Santa Cruz since the late 1970s — still surfing today</li>
        </ul>
      </div>

      <div class="prose prose-lg max-w-none">
        <!-- Paragraph 1 -->
        <p class="text-lg text-muted-foreground leading-relaxed mb-6">
          Hi! I'm <strong>Matt O'Leary</strong>, and I grew up in Santa Cruz and
          have spent countless hours exploring the beaches, redwoods, and
          neighborhoods that make this area so special.
        </p>

        <p class="text-lg text-muted-foreground leading-relaxed mb-6">
          Over the years, I've developed a deep appreciation for studying the
          history, architecture, and natural surroundings of the Santa Cruz
          area. What began as casual walks with friends has grown into a passion
          for sharing what I've learned — helping visitors and locals alike
          discover the hidden gems and stories that make this place unique.
        </p>

        <!-- Hiking photo (Pescadero) -->
        <div class="mb-6">
          <div class="aspect-[4/3] rounded-lg overflow-hidden">
            <Image
              src={pescaderoPhoto}
              alt="Walking in Pescadero"
              class="w-full h-full object-cover object-bottom"
              loading="lazy"
              quality={80}
            />
          </div>
        </div>

        <!-- Paragraph 2 -->
        <p class="text-lg text-muted-foreground leading-relaxed mb-6">
          My background in design and writing informs every Walk Santa Cruz tour — the pacing, the details, the story arc. I've also taught surf lessons both casually and professionally, and I enjoy spending time outdoors with family and friends — whether it's hiking to waterfalls and ocean views or urban exploration. That same spirit of sharing what I love inspired me to start Walk Santa Cruz.
        </p>

        <!-- Cave/Beach photo -->
        <div class="mb-6">
          <div class="aspect-[3/2] rounded-lg overflow-hidden">
            <Image
              src={aboutPhoto}
              alt="Matt leading a walking tour"
              class="w-full h-full object-cover"
              loading="eager"
              quality={80}
            />
          </div>
        </div>

        <!-- Downtown tour photo -->
        <div class="mb-6">
          <div class="aspect-[3/4] rounded-lg overflow-hidden">
            <Image
              src={downtownTourPhoto}
              alt="Matt guiding a group on a downtown Santa Cruz walking tour"
              class="w-full h-full object-cover"
              loading="lazy"
              quality={80}
            />
          </div>
        </div>

        <!-- Church tower tour photo -->
        <div class="mb-6">
          <div class="aspect-[4/3] rounded-lg overflow-hidden">
            <Image
              src={churchTowerTourPhoto}
              alt="Matt with a tour group near the Town Clock in Santa Cruz"
              class="w-full h-full object-cover"
              loading="lazy"
              quality={80}
            />
          </div>
        </div>

        <p class="text-lg text-muted-foreground leading-relaxed mb-6">
          I believe the best way to experience this place is on foot — it's a
          healthy, fun way to slow down, take in the scenery, and connect with
          the stories and landscapes that define Santa Cruz.
        </p>

        <!-- Paragraph 3 -->
        <p class="text-lg text-muted-foreground leading-relaxed mb-8">
          We look forward to walking with you soon! Feel free to reach out if
          you're interested in <a
            href="/private-tours"
            class="text-primary hover:underline"
          >private tours</a
          > or <a
            href="/team-offsites"
            class="text-primary hover:underline"
          >team offsites</a>.
        </p>
      </div>

      <!-- Walk With Matt CTA -->
      <div class="text-center mt-12">
        <h2 class="text-2xl md:text-3xl font-bold mb-3">Walk With Matt</h2>
        <p class="text-lg text-muted-foreground mb-6">Small groups, personal attention, stories you won't find in any guidebook.</p>
        <a href="/tours/surfing-beach-culture" data-astro-reload class="btn btn-lg">See Available Tours</a>
      </div>
    </div>
  </section>

  <!-- Why Walk With Us -->
  <section class="full-bleed relative py-16 md:py-24">
    <div
      class="absolute inset-0 opacity-50"
      style={`background-image: url(${mapBg.src}); background-size: cover; background-position: center;`}
    >
    </div>
    <div class="container relative">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center">
          Why Walk With Us
        </h2>

        <div class="grid md:grid-cols-2 gap-8">
          <div class="card">
            <div class="p-6">
              <h3 class="font-semibold text-lg mb-3">Local Expertise</h3>
              <p class="text-muted-foreground">
                Our guides are Santa Cruz have deep knowledge and passion for
                our community's history and culture.
              </p>
            </div>
          </div>

          <div class="card">
            <div class="p-6">
              <h3 class="font-semibold text-lg mb-3">Small Groups</h3>
              <p class="text-muted-foreground">
                Enjoy personalized attention with our small group sizes or opt
                for a private tour or team offsite experience.
              </p>
            </div>
          </div>

          <div class="card">
            <div class="p-6">
              <h3 class="font-semibold text-lg mb-3">Hidden Gems</h3>
              <p class="text-muted-foreground">
                Discover secret spots and fascinating stories that even locals
                might not know about.
              </p>
            </div>
          </div>

          <div class="card">
            <div class="p-6">
              <h3 class="font-semibold text-lg mb-3">Easy & Accessible</h3>
              <p class="text-muted-foreground">
                Our tours are designed to be comfortable for most fitness levels
                with plenty of stops along the way.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
